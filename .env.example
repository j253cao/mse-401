# Google Gemini API Key
# Required for resume analysis and course prerequisite parsing
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# Multiple Gemini API Keys (optional, for higher throughput)
# Comma-separated list of API keys for batch processing
# With 4 keys, you get 4x the rate limit (60 RPM instead of 15 RPM)
# GEMINI_API_KEYS="key1,key2,key3,key4"

# Waterloo OpenData API Key
# Required for fetching course data
# Get your API key from: https://openapi.data.uwaterloo.ca/v3/account/register
# Register with your email, project name, description, and project URL
# Confirm your email to activate the API key
WATERLOO_API_KEY="your-waterloo-api-key-here"
